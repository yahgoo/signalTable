# SignalTable profile environment variables
# Deploy to: ~/.hermes/profiles/signaltable/.env
# DO NOT commit this file with real values populated

# ── Telegram (inherited from default profile if cloned, verify these are correct) ──
# TELEGRAM_BOT_TOKEN=<from default profile .env>
# TELEGRAM_ALLOWED_USERS=1697120790
# TELEGRAM_HOME_CHANNEL=1697120790

# ── Google Calendar (direct API via gcal.py) ──
GOOGLE_CALENDAR_ID=REPLACE_WITH_CALENDAR_ID
GOOGLE_CREDENTIALS_FILE=/home/ubuntu/.hermes/profiles/signaltable/gcal-credentials.json

# ── LobsterMail (agent email inbox) ──
# Auto-provisioned on first MCP use; set manually if you have a key:
# LM_API_KEY=lm_sk_live_REPLACE_WITH_YOUR_KEY
LOBSTERMAIL_INBOX_ADDRESS=signaltable-reg@lobstermail.ai

# ── Steel Browser ──
STEEL_API_KEY=REPLACE_WITH_YOUR_KEY

# ── Apify (Luma structured discovery — read-only) ──
APIFY_TOKEN=
# Optional overrides (defaults shown):
# APIFY_ACTOR_ID=solidcode/luma-scraper
# APIFY_TASK_ID=

# ── Registration Identity ──
SIGNALTABLE_FULL_NAME=REPLACE_WITH_YOUR_FULL_NAME
